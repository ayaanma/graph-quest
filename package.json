{
  "name": "gradient-desc",
  "version": "0.0.0",
  "private": true,
  "description": "A synthwave function-graphing puzzle built for Reddit with Devvit Web.",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "npm run type-check && npm run format:check && npm run build",
    "deploy": "npm run check && devvit upload",
    "dev": "devvit playtest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "launch": "npm run deploy && devvit publish",
    "login": "devvit login",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "0.13.7",
    "@devvit/web": "0.13.7",
    "@hono/node-server": "2.0.8",
    "hono": "4.12.28"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "devvit": "0.13.7",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "vite": "8.1.3"
  }
}