{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "gradient-desc",
  "permissions": {
    "reddit": {
      "enable": true,
      "scope": "user",
      "asUser": ["SUBMIT_POST", "SUBMIT_COMMENT"]
    },
    "media": true
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "height": "tall"
      },
      "game": {
        "entry": "index.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create Gradient Descent post",
        "description": "Create a playable Gradient Descent post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "scheduler": {
    "tasks": {
      "publish-daily-level": {
        "endpoint": "/internal/scheduler/daily-post",
        "cron": "0 0 * * *"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "gradient_desc_dev"
  }
}
